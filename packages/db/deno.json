{
  "name": "@freebies/db",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "tasks": {
    "db:studio": "deno run --env-file -A drizzle-kit studio --verbose",
    "db:reset": "deno run --env-file -A ./src/reset.ts",
    "db:push": {
      "command": "deno run --env-file -A drizzle-kit push --force",
      "dependencies": ["db:reset"]
    },
    "db:seed": {
      "command": "deno run --env-file -A ./src/seed.ts",
      "dependencies": ["db:push"]
    }
  },
  "imports": {
    "drizzle-kit": "npm:drizzle-kit@beta",
    "drizzle-orm": "npm:drizzle-orm@beta",
    "@neondatabase/serverless": "npm:@neondatabase/serverless@^1.0.2",
    "pg": "npm:pg@^8.21.0"
  }
}

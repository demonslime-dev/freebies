{
  "name": "@freebies/db",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "tasks": {
    "db:push": "deno run --env-file -A drizzle-kit push --force",
    "db:studio": "deno run --env-file -A drizzle-kit studio --verbose",
    "db:seed": "deno run --env-file -A ./src/private/createUsers.ts"
  },
  "imports": {
    "drizzle-kit": "npm:drizzle-kit@beta",
    "drizzle-orm": "npm:drizzle-orm@beta",
    "@neondatabase/serverless": "npm:@neondatabase/serverless@^1.0.2",
    "pg": "npm:pg@^8.21.0"
  }
}
